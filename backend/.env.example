# Copy to `.env` in this folder (never commit real secrets).
# See `backend/README.md` for full documentation.

# Required for full API (employees + attendance). Empty = degraded mode (/health only OK).
MONGODB_URI=mongodb://localhost:27017

MONGODB_DB_NAME=hrms_lite

# Comma-separated browser origins (Vite dev server: http://localhost:5173)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

LOG_LEVEL=INFO

# `text` (default) or `json` — JSON = one object per line for log aggregators
LOG_FORMAT=text

# Set false in production to disable /docs, /redoc, /openapi.json
DOCS_ENABLED=true
